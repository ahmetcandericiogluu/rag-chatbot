{% extends 'base.html.twig' %}

{% block title %}idefix RAG Chatbot{% endblock %}

{% block body %}
<style>
    body {
        background: #f4f6f8;
    }

    .chat-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 32px 16px;
        font-family: Arial, sans-serif;
    }

    .chat-shell {
        width: 100%;
        max-width: 1180px;
        height: 760px;
        background: #ffffff;
        border-radius: 18px;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }

    .chat-header {
        padding: 20px 24px;
        background: linear-gradient(135deg, #111827, #374151);
        color: #ffffff;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chat-title {
        margin: 0;
        font-size: 22px;
        font-weight: 700;
    }

    .chat-subtitle {
        margin-top: 4px;
        font-size: 13px;
        color: #d1d5db;
    }

    .chat-badge {
        font-size: 12px;
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 7px 10px;
        border-radius: 999px;
        white-space: nowrap;
    }

    .chat-messages {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        background: #f9fafb;
    }

    .empty-state {
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        color: #6b7280;
        text-align: center;
    }

    .empty-card {
        max-width: 460px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px;
    }

    .empty-card h2 {
        margin: 0 0 8px;
        font-size: 20px;
        color: #111827;
    }

    .empty-card p {
        margin: 0 0 18px;
        line-height: 1.5;
    }

    .quick-prompts {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
    }

    .quick-prompt {
        border: 1px solid #d1d5db;
        background: #ffffff;
        border-radius: 999px;
        padding: 8px 12px;
        cursor: pointer;
        font-size: 13px;
    }

    .quick-prompt:hover {
        background: #f3f4f6;
    }

    .message-row {
        display: flex;
        margin-bottom: 18px;
    }

    .message-row.user {
        justify-content: flex-end;
    }

    .message-row.bot {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 75%;
        padding: 13px 15px;
        border-radius: 16px;
        line-height: 1.45;
        font-size: 15px;
        word-wrap: break-word;
    }

    .message-row.user .message-bubble {
        background: #111827;
        color: #ffffff;
        border-bottom-right-radius: 4px;
    }

    .message-row.bot .message-bubble {
        background: #ffffff;
        color: #111827;
        border: 1px solid #e5e7eb;
        border-bottom-left-radius: 4px;
    }

    .message-label {
        font-size: 11px;
        margin-bottom: 5px;
        opacity: 0.7;
    }

    .sources {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .source-card {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px;
        font-size: 12px;
    }

    .source-title {
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .source-meta {
        color: #6b7280;
        margin-bottom: 6px;
    }

    .source-content {
        color: #374151;
        line-height: 1.35;
    }

    .chat-footer {
        padding: 16px;
        border-top: 1px solid #e5e7eb;
        background: #ffffff;
    }

    .chat-form {
        display: flex;
        gap: 10px;
    }

    .chat-input {
        flex: 1;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        padding: 13px 14px;
        font-size: 15px;
        outline: none;
    }

    .chat-input:focus {
        border-color: #111827;
        box-shadow: 0 0 0 3px rgba(17, 24, 39, 0.08);
    }

    .send-button {
        border: 0;
        border-radius: 12px;
        background: #111827;
        color: #ffffff;
        padding: 0 20px;
        font-size: 15px;
        cursor: pointer;
        min-width: 110px;
    }

    .send-button:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .typing {
        display: inline-flex;
        gap: 4px;
        align-items: center;
    }

    .typing span {
        width: 6px;
        height: 6px;
        background: #9ca3af;
        border-radius: 50%;
        animation: blink 1.2s infinite ease-in-out;
    }

    .typing span:nth-child(2) {
        animation-delay: 0.15s;
    }

    .typing span:nth-child(3) {
        animation-delay: 0.3s;
    }

    .chat-main {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .sources-panel {
        border-left: 1px solid #e5e7eb;
        background: #ffffff;
        display: flex;
        flex-direction: column;
    }

    .sources-panel-header {
        padding: 18px 18px 14px;
        border-bottom: 1px solid #e5e7eb;
    }

    .sources-panel-title {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: #111827;
    }

    .sources-panel-subtitle {
        margin-top: 4px;
        font-size: 12px;
        color: #6b7280;
    }

    .sources-panel-body {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        background: #f9fafb;
    }

    .sources-empty {
        color: #6b7280;
        font-size: 13px;
        line-height: 1.5;
        background: #ffffff;
        border: 1px dashed #d1d5db;
        border-radius: 12px;
        padding: 14px;
    }

    .source-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        font-size: 12px;
        margin-bottom: 10px;
    }

    .source-title {
        font-weight: 700;
        color: #111827;
        margin-bottom: 5px;
    }

    .source-meta {
        color: #6b7280;
        margin-bottom: 8px;
        font-size: 11px;
    }

    .source-content {
        color: #374151;
        line-height: 1.45;
    }

    .source-path {
        margin-top: 8px;
        color: #6b7280;
        font-size: 11px;
        word-break: break-all;
    }

    @keyframes blink {
        0%, 80%, 100% {
            opacity: 0.3;
            transform: translateY(0);
        }
        40% {
            opacity: 1;
            transform: translateY(-3px);
        }
    }

    @media (max-width: 900px) {
        .chat-shell {
            height: 90vh;
            border-radius: 12px;
            grid-template-columns: 1fr;
        }

        .sources-panel {
            display: none;
        }

        .message-bubble {
            max-width: 88%;
        }

        .chat-header {
            align-items: flex-start;
            gap: 12px;
            flex-direction: column;
        }

        .send-button {
            min-width: 84px;
        }
    }
</style>

<div class="chat-page">
    <div class="chat-shell">
        <section class="chat-main">
            <header class="chat-header">
                <div>
                    <h1 class="chat-title">idefix RAG Chatbot</h1>
                    <div class="chat-subtitle">PostgreSQL + pgvector + Ollama ile kaynak destekli cevaplama</div>
                </div>

                <div class="chat-badge">Local RAG API bağlı</div>
            </header>

            <main id="messages" class="chat-messages">
                <div id="empty-state" class="empty-state">
                    <div class="empty-card">
                        <h2>Nasıl yardımcı olabilirim?</h2>
                        <p>İade, teslimat veya ödeme bilgileriyle ilgili bir soru sorabilirsin.</p>

                        <div class="quick-prompts">
                            <button class="quick-prompt" type="button">İade süresi kaç gündür?</button>
                            <button class="quick-prompt" type="button">İstanbul içi teslimat kaç gün sürer?</button>
                            <button class="quick-prompt" type="button">Hangi ödeme yöntemleri var?</button>
                        </div>
                    </div>
                </div>
            </main>

            <footer class="chat-footer">
                <form id="chat-form" class="chat-form">
                    <input
                        id="message-input"
                        class="chat-input"
                        type="text"
                        placeholder="Sorunu yaz..."
                        autocomplete="off"
                    >

                    <button id="send-button" class="send-button" type="submit">
                        Gönder
                    </button>
                </form>
            </footer>
        </section>

        <aside class="sources-panel">
            <div class="sources-panel-header">
                <h2 class="sources-panel-title">Kullanılan Kaynaklar</h2>
                <div class="sources-panel-subtitle">Son cevabın dayandığı chunk bilgileri</div>
            </div>

            <div id="sources-panel-body" class="sources-panel-body">
                <div class="sources-empty">
                    Henüz bir kaynak kullanılmadı. Bir soru sorduğunda son cevabın kaynakları burada görünecek.
                </div>
            </div>
        </aside>
    </div>
</div>

<script>
    const form = document.getElementById('chat-form');
    const input = document.getElementById('message-input');
    const messages = document.getElementById('messages');
    const sendButton = document.getElementById('send-button');
    const emptyState = document.getElementById('empty-state');
    const sourcesPanelBody = document.getElementById('sources-panel-body');

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function scrollToBottom() {
        messages.scrollTop = messages.scrollHeight;
    }

    function hideEmptyState() {
        if (emptyState) {
            emptyState.style.display = 'none';
        }
    }

    function addUserMessage(text) {
        hideEmptyState();

        const row = document.createElement('div');
        row.className = 'message-row user';

        row.innerHTML = `
            <div class="message-bubble">
                <div class="message-label">Sen</div>
                ${escapeHtml(text)}
            </div>
        `;

        messages.appendChild(row);
        scrollToBottom();
    }

    function addBotMessage(answer) {
        hideEmptyState();

        const row = document.createElement('div');
        row.className = 'message-row bot';

        const safeAnswer = escapeHtml(answer);

        row.innerHTML = `
            <div class="message-bubble">
                <div class="message-label">Bot</div>
                ${safeAnswer}
            </div>
        `;

        messages.appendChild(row);
        scrollToBottom();
    }

    function addTypingMessage() {
        hideEmptyState();

        const row = document.createElement('div');
        row.className = 'message-row bot';
        row.id = 'typing-message';

        row.innerHTML = `
            <div class="message-bubble">
                <div class="message-label">Bot</div>
                <div class="typing">
                    <span></span><span></span><span></span>
                </div>
            </div>
        `;

        messages.appendChild(row);
        scrollToBottom();
    }

    function removeTypingMessage() {
        const typing = document.getElementById('typing-message');

        if (typing) {
            typing.remove();
        }
    }

    function setLoading(isLoading) {
        input.disabled = isLoading;
        sendButton.disabled = isLoading;
        sendButton.textContent = isLoading ? 'Bekle...' : 'Gönder';
    }

    async function sendMessage(message) {
        addUserMessage(message);
        addTypingMessage();
        setLoading(true);

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    message: message,
                }),
            });

            const data = await response.json();

            removeTypingMessage();

            if (!response.ok) {
                addBotMessage(data.error ?? 'Bir hata oluştu.');
                updateSourcesPanel([]);
                return;
            }

            addBotMessage(data.answer);
            updateSourcesPanel(data.sources ?? []);
        } catch (error) {
            removeTypingMessage();
            addBotMessage('Sunucuya bağlanırken bir hata oluştu.');
            updateSourcesPanel([]);
        } finally {
            setLoading(false);
            input.focus();
        }
    }

    form.addEventListener('submit', async function (event) {
        event.preventDefault();

        const message = input.value.trim();

        if (!message) {
            return;
        }

        input.value = '';

        await sendMessage(message);
    });

    document.querySelectorAll('.quick-prompt').forEach((button) => {
        button.addEventListener('click', async () => {
            const message = button.textContent.trim();

            if (message) {
                await sendMessage(message);
            }
        });
    });

    function updateSourcesPanel(sources = []) {
        if (!sourcesPanelBody) {
            return;
        }

        if (!sources || sources.length === 0) {
            sourcesPanelBody.innerHTML = `
                <div class="sources-empty">
                    Bu cevap için kaynak bulunamadı.
                </div>
            `;

            return;
        }

        sourcesPanelBody.innerHTML = sources.map((source, index) => `
            <div class="source-card">
                <div class="source-title">
                    ${index + 1}. ${escapeHtml(source.source_title ?? source.document_id ?? 'Bilinmeyen kaynak')}
                </div>

                <div class="source-meta">
                    Skor: ${Number(source.score ?? 0).toFixed(4)}
                    ${source.source_type ? ' • Tür: ' + escapeHtml(source.source_type) : ''}
                    ${source.chunk_no ? ' • Chunk: ' + escapeHtml(source.chunk_no) : ''}
                </div>

                <div class="source-content">
                    ${escapeHtml(source.content ?? '')}
                </div>

                ${source.source_path ? `
                    <div class="source-path">
                        ${escapeHtml(source.source_path)}
                    </div>
                ` : ''}
            </div>
        `).join('');
    }
</script>
{% endblock %}